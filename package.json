{
  "name": "@abdullah1bit/job-scanner",
  "version": "0.1.0",
  "description": "A deterministic, transparent ATS resume scoring engine. 8 rules, no black box, no LLM. Includes resume-to-job-description matching with synonym-aware keyword extraction.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src test",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "release": "semantic-release",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "ats",
    "resume",
    "scorer",
    "job-scanner",
    "ats-score",
    "ats-checker",
    "resume-matcher",
    "job-description-matcher",
    "ats-friendly",
    "open-source"
  ],
  "homepage": "https://github.com/abdullah1bit/job-scanner#readme",
  "bugs": "https://github.com/abdullah1bit/job-scanner/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/abdullah1bit/job-scanner.git"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "eslint": "^10.5.0",
    "prettier": "^3.2.0",
    "semantic-release": "^25.0.5",
    "tsup": "^8.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
